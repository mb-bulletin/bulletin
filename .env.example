# Copy to .env and fill in real values. The .env file is gitignored;
# it lives only on the production host.
#
# All variables here are REQUIRED unless marked optional. docker-compose
# fails fast if a required one is missing (see :? syntax in compose).

# The domain the app serves on. DNS must point at this box first;
# Caddy uses it both for the HTTPS hostname and the Let's Encrypt cert.
DOMAIN=bulletin.example.org

# Email shown on the cert and where Let's Encrypt sends expiration
# warnings. Don't use a personal address you'll lose access to.
ACME_EMAIL=ops@example.org

# Anthropic API key for the parser. Used only by the harness container,
# never by the api. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Image tag to run. Bumped at deploy time; defaults to "latest".
# VERSION=v0.2.0
